// User model
model User {
  id           String        @id @default(uuid())
  email        String?       @unique
  password     String?
  displayName  String?
  firebaseUid  String?       @unique
  photoUrl     String?
  provider     String?
  themeSetting String        @default("auto")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  conversations Conversation[]
  devices      Device[]

  @@map("users")
}
